{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["./src/core/index.ts"],
  "out": "./docs/api",
  "name": "Kustomark Core Library API",
  "includeVersion": true,
  "readme": "./README.md",
  "exclude": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/node_modules/**",
    "**/dist/**"
  ],
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeExternals": true,
  "excludeInternal": false,
  "excludeNotDocumented": false,
  "cleanOutputDir": true,
  "searchInComments": true,
  "searchInDocuments": true,
  "validation": {
    "notExported": true,
    "invalidLink": true,
    "notDocumented": false
  },
  "categorizeByGroup": true,
  "defaultCategory": "Other",
  "categoryOrder": [
    "Patch Engine",
    "Patch Operations",
    "Configuration",
    "Resources",
    "Frontmatter",
    "Table Operations",
    "File Operations",
    "Conditions",
    "Validation",
    "Security",
    "Testing",
    "Build Cache",
    "Templates",
    "Utilities",
    "*"
  ],
  "sort": ["source-order"],
  "kindSortOrder": [
    "Function",
    "Class",
    "Interface",
    "TypeAlias",
    "Enum",
    "Variable"
  ],
  "navigationLinks": {
    "GitHub": "https://github.com/dexhorthy/kustomark-ralph-bash",
    "Main Documentation": "../README.md"
  },
  "sidebarLinks": {
    "GitHub": "https://github.com/dexhorthy/kustomark-ralph-bash",
    "Report an Issue": "https://github.com/dexhorthy/kustomark-ralph-bash/issues"
  },
  "sourceLinkExternal": true,
  "gitRevision": "main",
  "disableSources": false,
  "includeHierarchySummary": true,
  "theme": "default",
  "lightHighlightTheme": "light-plus",
  "darkHighlightTheme": "dark-plus",
  "visibilityFilters": {
    "protected": false,
    "private": false,
    "inherited": true,
    "external": false
  },
  "searchGroupBoosts": {
    "Patch Engine": 2.0,
    "Patch Operations": 1.8,
    "Configuration": 1.5,
    "Types": 1.2
  },
  "commentStyle": "jsdoc",
  "blockTags": [
    "@deprecated",
    "@param",
    "@returns",
    "@throws",
    "@example",
    "@see",
    "@category",
    "@group",
    "@since",
    "@internal",
    "@remarks"
  ],
  "inlineTags": [
    "@link",
    "@linkcode",
    "@linkplain"
  ],
  "modifierTags": [
    "@public",
    "@private",
    "@protected",
    "@readonly",
    "@internal",
    "@deprecated"
  ],
  "titleLink": "/"
}
